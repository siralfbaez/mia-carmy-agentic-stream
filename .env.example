# File: .env.example
# --- Project Configuration ---
PROJECT_NAME=mia-carmy-agentic-stream
ENVIRONMENT=gov-dev # gov-dev, gov-stage

# --- AWS GovCloud / cArmy ---
AWS_REGION=us-gov-west-1
AWS_ACCOUNT_ID=your_gov_account_id
EKS_CLUSTER_NAME=mia-carmy-agentic-cluster

# --- Agentic AI / Brain ---
# Specify whether using Bedrock (AWS) or Vertex AI (GCP via PrivateLink)
AI_PROVIDER=vertex_ai 
AI_MODEL_ID=gemini-1.5-pro

# --- Infrastructure / Terraform ---
# Use IAM roles/Service Accounts, but placeholders here for local testing
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
TF_VAR_db_password=secure_password_from_vault

# --- Security & Compliance Mode ---
# When true, the Nervous System enforces STIG/CIS checks
HARDENING_ENFORCED=true
NIST_COMPLIANCE_LEVEL=MODERATE
